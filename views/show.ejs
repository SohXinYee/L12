<%- include('partials/header') %>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header">
                <h2 class="mb-0"><%= recipe.title %></h2>
            </div>
            <div class="card-body">
                <h5>Ingredients</h5>
                <ul class="list-group mb-4">
                    <% const ingredientsList = recipe.ingredients.split(',').map(i => i.trim()); %>
                    <% ingredientsList.forEach(ingredient => { %>
                        <li class="list-group-item"><%= ingredient %></li>
                    <% }); %>
                </ul>
                <p class="text-muted">Added <%= timeAgo(recipe.createdAt) %></p>
                <div class="mt-3">
                    <a href="/" class="btn btn-secondary">← Back to all recipes</a>
                    <a href="/edit/<%= recipe.id %>" class="btn btn-warning">Edit Recipe</a>
                    <form action="/delete/<%= recipe.id %>" method="POST" style="display:inline;">
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Delete this recipe?')">Delete</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>