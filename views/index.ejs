<%- include('partials/header') %>

<div class="row mb-4">
    <div class="col">
        <h1>My Recipe Box</h1>
        <p class="lead">Save just the ingredient lists – no fluff.</p>
    </div>
</div>

<!-- Search form (Good to Have) -->
<div class="card mb-4">
    <div class="card-body">
        <form method="GET" action="/" class="row g-3">
            <div class="col-md-8">
                <input type="text" name="search" class="form-control" placeholder="Search recipe titles..." value="<%= typeof search !== 'undefined' ? search : '' %>">
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary">🔍 Search</button>
                <a href="/" class="btn btn-secondary">Clear</a>
            </div>
        </form>
    </div>
</div>

<% if (recipes.length === 0) { %>
    <div class="alert alert-info">No recipes yet. <a href="/add">Add your first recipe</a></div>
<% } else { %>
    <div class="row">
        <% recipes.forEach(recipe => { %>
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title"><%= recipe.title %></h5>
                        <!-- Ingredient count badge -->
                        <% const ingredientCount = recipe.ingredients.split(',').length; %>
                        <span class="badge bg-info mb-2"><%= ingredientCount %> ingredient(s)</span>
                        <p class="card-text small text-muted">Added <%= timeAgo(recipe.createdAt) %></p>
                        <div class="d-flex justify-content-between">
                            <a href="/recipe/<%= recipe.id %>" class="btn btn-primary btn-sm">View Ingredients</a>
                            <a href="/edit/<%= recipe.id %>" class="btn btn-warning btn-sm">Edit</a>
                            <form action="/delete/<%= recipe.id %>" method="POST" style="display:inline;">
                                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Delete this recipe?')">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        <% }); %>
    </div>
<% } %>

<div class="mt-3">
    <a href="/add" class="btn btn-success">+ Add New Recipe</a>
</div>

<%- include('partials/footer') %>